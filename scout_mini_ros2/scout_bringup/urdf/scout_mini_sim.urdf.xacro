<?xml version="1.0"?>
<!--
  scout_mini_sim.urdf.xacro
  =========================
  Scout Mini URDF for Gazebo Classic 11 + ROS2 Humble.

  This file is used exclusively for SIMULATION. The real robot uses the
  scout_base_node driver which reads directly from the CAN bus.

  Drive plugin: gazebo_ros_skid_steer_drive
    - Controls all 4 wheels as two groups (left/right)
    - Subscribes to /cmd_vel (geometry_msgs/Twist)
    - Publishes /odom (nav_msgs/Odometry)

  Sensors:
    - 2D LiDAR: 360°, 12 m range → /scan (sensor_msgs/LaserScan)
    - IMU: 6-DOF, 100 Hz → /imu/data (sensor_msgs/Imu)

  Frame tree:
    odom → base_footprint → base_link
                          ├── wheel_front_left_link
                          ├── wheel_front_right_link
                          ├── wheel_rear_left_link
                          ├── wheel_rear_right_link
                          ├── lidar_link
                          └── imu_link

  Authors: Milad (TA), Autonomous Mobile Robots, UFSCar 2025
-->
<robot name="scout_mini" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ═══ PARAMETERS ════════════════════════════════════════════════════ -->
  <!-- Scout Mini hardware dimensions (from AgileX datasheet) -->
  <xacro:property name="base_length"    value="0.600"/>
  <xacro:property name="base_width"     value="0.450"/>
  <xacro:property name="base_height"    value="0.175"/>
  <xacro:property name="base_mass"      value="30.0"/>
  <xacro:property name="clearance"      value="0.085"/>

  <xacro:property name="wheel_radius"   value="0.0875"/>
  <xacro:property name="wheel_width"    value="0.055"/>
  <xacro:property name="wheel_mass"     value="1.5"/>
  <xacro:property name="track"          value="0.4671"/>   <!-- L-R wheel centre distance -->
  <xacro:property name="wheelbase"      value="0.498"/>    <!-- front-rear axle distance -->

  <xacro:property name="lidar_z"        value="0.22"/>     <!-- height above base_link origin -->
  <xacro:property name="pi"             value="3.14159265358979"/>

  <!-- ═══ INERTIA MACROS ════════════════════════════════════════════════ -->
  <xacro:macro name="box_inertia" params="m l w h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(w*w+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(l*l+h*h)/12}" iyz="0"
               izz="${m*(l*l+w*w)/12}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cyl_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+h*h)/12}" iyz="0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- ═══ WHEEL MACRO ═══════════════════════════════════════════════════
       Uses real mesh files from the scout_description package.
       mesh_type: wheel_type1 (front wheels) or wheel_type2 (rear wheels)
       Visual uses the real DAE mesh; collision uses a cylinder for physics.
  ═══════════════════════════════════════════════════════════════════ -->
  <xacro:macro name="wheel" params="prefix x_pos y_pos mesh_type">
    <link name="wheel_${prefix}_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://scout_description/meshes/${mesh_type}.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cyl_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="wheel_${prefix}_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="wheel_${prefix}_link"/>
      <origin xyz="${x_pos} ${y_pos} ${-clearance}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1" friction="0.2"/>
    </joint>

    <!-- Gazebo wheel friction properties -->
    <gazebo reference="wheel_${prefix}_link">
      <mu1>1.0</mu1>
      <mu2>0.5</mu2>
      <kp>500000.0</kp>
      <kd>10.0</kd>
      <minDepth>0.001</minDepth>
      <maxVel>0.1</maxVel>
    </gazebo>
  </xacro:macro>

  <!-- ═══ BASE LINKS ════════════════════════════════════════════════════ -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${clearance + wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- Real Scout Mini body mesh from scout_description package -->
        <mesh filename="package://scout_description/meshes/base_link.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- Box collision is simpler and faster than mesh collision -->
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${base_mass}"
                       l="${base_length}" w="${base_width}" h="${base_height}"/>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/Orange</material>
  </gazebo>

  <!-- ═══ FOUR WHEELS ═══════════════════════════════════════════════════
       front wheels use wheel_type1.dae, rear wheels use wheel_type2.dae
  ═══════════════════════════════════════════════════════════════════ -->
  <xacro:wheel prefix="front_left"  x_pos="${wheelbase/2}"  y_pos="${track/2}"  mesh_type="wheel_type1"/>
  <xacro:wheel prefix="front_right" x_pos="${wheelbase/2}"  y_pos="${-track/2}" mesh_type="wheel_type1"/>
  <xacro:wheel prefix="rear_left"   x_pos="${-wheelbase/2}" y_pos="${track/2}"  mesh_type="wheel_type2"/>
  <xacro:wheel prefix="rear_right"  x_pos="${-wheelbase/2}" y_pos="${-track/2}" mesh_type="wheel_type2"/>

  <!-- ═══ LIDAR LINK ════════════════════════════════════════════════════ -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.07"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.07"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0.0 0.0 ${base_height/2 + lidar_z}" rpy="0 0 0"/>
  </joint>

  <!-- ═══ IMU LINK ══════════════════════════════════════════════════════ -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.02"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.3 0.8 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════════
       GAZEBO CLASSIC PLUGINS
       ═══════════════════════════════════════════════════════════════════ -->

  <!--
    Skid-Steer Drive Plugin
    =======================
    Controls 4 wheels as two groups (left: FL+RL, right: FR+RR).
    Internally performs inverse kinematics:
      v_L = v - (wheelSeparation/2) * rot
      v_R = v + (wheelSeparation/2) * rot

    Subscribes : /cmd_vel  (geometry_msgs/Twist)
    Publishes  : /odom     (nav_msgs/Odometry)
                 /tf       (odom → base_footprint)
  -->
  <gazebo>
    <plugin name="skid_steer_drive" filename="libgazebo_ros_skid_steer_drive.so">
      <ros>
        <namespace>/</namespace>
      </ros>

      <!-- Wheel joints — left side -->
      <left_front_joint>wheel_front_left_joint</left_front_joint>
      <left_rear_joint>wheel_rear_left_joint</left_rear_joint>
      <!-- Wheel joints — right side -->
      <right_front_joint>wheel_front_right_joint</right_front_joint>
      <right_rear_joint>wheel_rear_right_joint</right_rear_joint>

      <!-- Kinematic parameters -->
      <wheel_separation>${track}</wheel_separation>
      <wheel_diameter>${2 * wheel_radius}</wheel_diameter>

      <!-- Robot velocity limits (Scout Mini hardware specs) -->
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>

      <!-- Topic names -->
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>

      <!-- Publish odometry TF -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>

      <update_rate>50</update_rate>
    </plugin>
  </gazebo>

  <!--
    2D LiDAR Sensor (GPU Ray)
    =========================
    Simulates a 360° scanning LiDAR at 10 Hz.
    Publishes: /scan (sensor_msgs/LaserScan)
  -->
  <gazebo reference="lidar_link">
    <sensor type="gpu_ray" name="lidar_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>${-pi}</min_angle>
            <max_angle>${pi}</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_lidar" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!--
    IMU Sensor
    ==========
    6-DOF inertial measurement unit at 100 Hz.
    Publishes: /imu/data (sensor_msgs/Imu)
  -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>false</visualize>
      <plugin name="gazebo_ros_imu" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

</robot>
