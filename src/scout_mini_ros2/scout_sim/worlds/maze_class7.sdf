<?xml version="1.0"?>
<sdf version='1.8'>
    <world name='maze'>
        <physics name='1ms' type='ignored'>
            <max_step_size>0.003</max_step_size>
            <real_time_factor>1</real_time_factor>
            <real_time_update_rate>1000</real_time_update_rate>
        </physics>

        <plugin name="gz::sim::systems::Physics" filename="gz-sim-physics-system" />
        <plugin name="gz::sim::systems::UserCommands" filename="gz-sim-user-commands-system" />
        <plugin name="gz::sim::systems::SceneBroadcaster" filename="gz-sim-scene-broadcaster-system" />
        <plugin name="gz::sim::systems::Contact" filename="gz-sim-contact-system" />
        <plugin filename="gz-sim-sensors-system"
                name="gz::sim::systems::Sensors">
            <render_engine>ogre2</render_engine>
        </plugin>
        <plugin filename="gz-sim-imu-system"
                name="gz::sim::systems::Imu"/>

        <light name='sun' type='directional'>
            <cast_shadows>1</cast_shadows>
            <pose>0 0 10 0 -0 0</pose>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
            <attenuation>
                <range>1000</range>
                <constant>0.90000000000000002</constant>
                <linear>0.01</linear>
                <quadratic>0.001</quadratic>
            </attenuation>
            <direction>-0.5 0.1 -0.9</direction>
            <spot>
                <inner_angle>0</inner_angle>
                <outer_angle>0</outer_angle>
                <falloff>0</falloff>
            </spot>
        </light>
        <gravity>0 0 -9.8</gravity>
        <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
        <atmosphere type='adiabatic' />
        <scene>
            <ambient>0.4 0.4 0.4 1</ambient>
            <background>0.7 0.7 0.7 1</background>
            <shadows>1</shadows>
        </scene>

        <!-- ── Ground plane ──────────────────────────────────────────── -->
        <model name='ground_plane'>
            <static>1</static>
            <link name='link'>
                <collision name='collision'>
                    <geometry>
                        <plane>
                            <normal>0 0 1</normal>
                            <size>100 100</size>
                        </plane>
                    </geometry>
                    <surface>
                        <friction><ode /></friction>
                        <bounce />
                        <contact />
                    </surface>
                </collision>
                <visual name='visual'>
                    <geometry>
                        <plane>
                            <normal>0 0 1</normal>
                            <size>100 100</size>
                        </plane>
                    </geometry>
                    <material>
                        <ambient>0.8 0.8 0.8 1</ambient>
                        <diffuse>0.8 0.8 0.8 1</diffuse>
                        <specular>0.8 0.8 0.8 1</specular>
                    </material>
                </visual>
            </link>
            <pose>0 0 0 0 -0 0</pose>
        </model>

        <!-- ── Border walls (20 × 20 m arena) ──────────────────────── -->
        <model name='border'>
            <pose>0 0 1 0 0 0</pose>
            <static>true</static>
            <link name='wall1'>
                <pose>-10.005 0 0 0 0 0</pose>
                <collision name='wall1_collision'>
                    <geometry><box><size>0.01 20 2</size></box></geometry>
                </collision>
                <visual name='wall1_visual'>
                    <geometry><box><size>0.01 20 2</size></box></geometry>
                    <material>
                        <ambient>0.1 0.1 0.1 1</ambient>
                        <diffuse>0 0.01 0.05 1</diffuse>
                        <specular>0 0.01 0.05 1</specular>
                    </material>
                </visual>
            </link>
            <link name='wall2'>
                <pose>10.005 0 0 0 0 0</pose>
                <collision name='wall2_collision'>
                    <geometry><box><size>0.01 20 2</size></box></geometry>
                </collision>
                <visual name='wall2_visual'>
                    <geometry><box><size>0.01 20 2</size></box></geometry>
                    <material>
                        <ambient>0.1 0.1 0.1 1</ambient>
                        <diffuse>0 0.01 0.05 1</diffuse>
                        <specular>0 0.01 0.05 1</specular>
                    </material>
                </visual>
            </link>
            <link name='wall3'>
                <pose>0 10.005 0 0 0 0</pose>
                <collision name='wall3_collision'>
                    <geometry><box><size>20 0.01 2</size></box></geometry>
                </collision>
                <visual name='wall3_visual'>
                    <geometry><box><size>20 0.01 2</size></box></geometry>
                    <material>
                        <ambient>0.1 0.1 0.1 1</ambient>
                        <diffuse>0 0.01 0.05 1</diffuse>
                        <specular>0 0.01 0.05 1</specular>
                    </material>
                </visual>
            </link>
            <link name='wall4'>
                <pose>0 -10.005 0 0 0 0</pose>
                <collision name='wall4_collision'>
                    <geometry><box><size>20 0.01 2</size></box></geometry>
                </collision>
                <visual name='wall4_visual'>
                    <geometry><box><size>20 0.01 2</size></box></geometry>
                    <material>
                        <ambient>0.1 0.1 0.1 1</ambient>
                        <diffuse>0 0.01 0.05 1</diffuse>
                        <specular>0 0.01 0.05 1</specular>
                    </material>
                </visual>
            </link>
        </model>

        <!-- ── Maze walls — Week 7 ───────────────────────────────────
             All walls are 1 m tall. The obstacles model is lifted 0.5 m
             by its pose so links sit flush on the ground plane.
        ─────────────────────────────────────────────────────────────── -->
        <model name='obstacles'>
            <pose>0 0 0.5 0 0 0</pose>
            <static>true</static>

            <!-- wall1: horizontal — center(-7, 5.5), size(6×1) -->
            <link name='wall1'>
                <pose>-7 5.5 0 0 0 0</pose>
                <collision name='wall1_collision'>
                    <geometry><box><size>6 1 1</size></box></geometry>
                </collision>
                <visual name='wall1_visual'>
                    <geometry><box><size>6 1 1</size></box></geometry>
                    <material>
                        <ambient>0.1 0.1 0.1 1</ambient>
                        <diffuse>0 0.1 0.2 1</diffuse>
                        <specular>0 0.01 0.05 1</specular>
                    </material>
                </visual>
            </link>

            <!-- wall2: vertical — center(-5.5, -2.5), size(1×7) -->
            <link name='wall2'>
                <pose>-5.5 -2.5 0 0 0 0</pose>
                <collision name='wall2_collision'>
                    <geometry><box><size>1 7 1</size></box></geometry>
                </collision>
                <visual name='wall2_visual'>
                    <geometry><box><size>1 7 1</size></box></geometry>
                    <material>
                        <ambient>0.1 0.1 0.1 1</ambient>
                        <diffuse>0 0.1 0.2 1</diffuse>
                        <specular>0 0.01 0.05 1</specular>
                    </material>
                </visual>
            </link>

            <!-- wall3: horizontal — center(-2, 0.5), size(6×1) -->
            <link name='wall3'>
                <pose>-2 0.5 0 0 0 0</pose>
                <collision name='wall3_collision'>
                    <geometry><box><size>6 1 1</size></box></geometry>
                </collision>
                <visual name='wall3_visual'>
                    <geometry><box><size>6 1 1</size></box></geometry>
                    <material>
                        <ambient>0.1 0.1 0.1 1</ambient>
                        <diffuse>0 0.1 0.2 1</diffuse>
                        <specular>0 0.01 0.05 1</specular>
                    </material>
                </visual>
            </link>

            <!-- wall4: vertical — center(0.5, 5.5), size(1×9) -->
            <link name='wall4'>
                <pose>0.5 5.5 0 0 0 0</pose>
                <collision name='wall4_collision'>
                    <geometry><box><size>1 9 1</size></box></geometry>
                </collision>
                <visual name='wall4_visual'>
                    <geometry><box><size>1 9 1</size></box></geometry>
                    <material>
                        <ambient>0.1 0.1 0.1 1</ambient>
                        <diffuse>0 0.1 0.2 1</diffuse>
                        <specular>0 0.01 0.05 1</specular>
                    </material>
                </visual>
            </link>

            <!-- wall5: vertical — center(0.5, -7), size(1×6) -->
            <link name='wall5'>
                <pose>0.5 -7 0 0 0 0</pose>
                <collision name='wall5_collision'>
                    <geometry><box><size>1 6 1</size></box></geometry>
                </collision>
                <visual name='wall5_visual'>
                    <geometry><box><size>1 6 1</size></box></geometry>
                    <material>
                        <ambient>0.1 0.1 0.1 1</ambient>
                        <diffuse>0 0.1 0.2 1</diffuse>
                        <specular>0 0.01 0.05 1</specular>
                    </material>
                </visual>
            </link>

            <!-- wall6: horizontal — center(3.5, -4.5), size(5×1) -->
            <link name='wall6'>
                <pose>3.5 -4.5 0 0 0 0</pose>
                <collision name='wall6_collision'>
                    <geometry><box><size>5 1 1</size></box></geometry>
                </collision>
                <visual name='wall6_visual'>
                    <geometry><box><size>5 1 1</size></box></geometry>
                    <material>
                        <ambient>0.1 0.1 0.1 1</ambient>
                        <diffuse>0 0.1 0.2 1</diffuse>
                        <specular>0 0.01 0.05 1</specular>
                    </material>
                </visual>
            </link>

            <!-- wall7: vertical — center(5.5, 1), size(1×10) -->
            <link name='wall7'>
                <pose>5.5 1 0 0 0 0</pose>
                <collision name='wall7_collision'>
                    <geometry><box><size>1 10 1</size></box></geometry>
                </collision>
                <visual name='wall7_visual'>
                    <geometry><box><size>1 10 1</size></box></geometry>
                    <material>
                        <ambient>0.1 0.1 0.1 1</ambient>
                        <diffuse>0 0.1 0.2 1</diffuse>
                        <specular>0 0.01 0.05 1</specular>
                    </material>
                </visual>
            </link>

        </model>
    </world>
</sdf>
